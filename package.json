{
  "name": "@zerob13/nativekit",
  "version": "0.5.0",
  "description": "Cross-platform native capabilities for Electron: overlays, window awareness, and app icons.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "build": "pnpm build:js && pnpm build:native",
    "build:js": "vite build && tsc -p tsconfig.build.json",
    "build:native": "cmake-js build",
    "build:mac": "cmake-js build --arch=arm64 --out=build/darwin-arm64 && cmake-js build --arch=x64 --out=build/darwin-x64",
    "build:win": "cmake-js build --arch=x64 --out=build/win32-x64",
    "build:linux": "cmake-js build",
    "prebuilds": "prebuildify --napi --strip",
    "test": "vitest run",
    "check": "pnpm build:js && tsc --noEmit && vitest run",
    "prepack": "pnpm build:js",
    "demo": "pnpm build && electron examples/electron",
    "demo:smoke": "pnpm build && electron examples/electron --smoke"
  },
  "binary": {
    "napi_versions": [
      8
    ]
  },
  "files": [
    "dist/",
    "prebuilds/",
    "binding.gyp",
    "CMakeLists.txt",
    "src/",
    "docs/",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerob13/nativekit.git"
  },
  "keywords": [
    "electron",
    "native",
    "addon",
    "n-api",
    "overlay",
    "window",
    "cross-platform"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "electron": ">=28"
  },
  "dependencies": {
    "node-addon-api": "^8.9.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "cmake-js": "^8.0.0",
    "electron": "^43.2.0",
    "node-gyp": "^13.0.1",
    "prebuildify": "^6.0.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
